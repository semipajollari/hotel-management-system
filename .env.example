# MongoDB connection string
# Use MongoDB Atlas for cloud: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/hotel-management

# NextAuth secret - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here

# App URL (use http://localhost:3000 locally)
NEXTAUTH_URL=http://localhost:3000

# Secret token for the one-time seed endpoint /api/seed?token=...
# Choose any random string, e.g.: myseedtoken2026
SEED_SECRET=myseedtoken2026
